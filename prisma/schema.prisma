// Prisma schema — SQLite for the local prototype.
// Run: npx prisma migrate dev   |   npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection used by the app at runtime (Neon -pooler host).
  url       = env("DATABASE_URL")
  // Direct (unpooled) connection used for migrations / db push.
  directUrl = env("DIRECT_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         String     @default("USER") // "USER" | "ADMIN"
  status       String     @default("ACTIVE") // "ACTIVE" | "SUSPENDED"
  // KYC / identity verification
  kycStatus     String    @default("UNVERIFIED") // UNVERIFIED | PENDING | VERIFIED | REJECTED
  idType        String?   // drivers_license | passport | state_id
  idLast4       String?
  faceCaptured  Boolean   @default(false)
  kycVerifiedAt DateTime?
  createdAt    DateTime   @default(now())

  accounts    Account[]
  transfers   Transfer[]
  withdrawals Withdrawal[]
}

model Withdrawal {
  id            String   @id @default(cuid())
  reference     String   @unique
  userId        String
  accountId     String
  isEarly       Boolean  @default(true)  // under age 59½
  reason        String?
  gross         Float
  penaltyRate   Float    @default(0.10)  // IRS 10% early-withdrawal additional tax
  penalty       Float
  taxRate       Float    @default(0.10)  // federal income tax withholding
  tax           Float
  net           Float
  items         String   @default("[]")  // JSON of liquidated positions
  cashPortion   Float    @default(0)
  form1099R     String   // generated IRS distribution form reference
  irsReportedAt DateTime?
  status        String   @default("REPORTED") // REPORTED | COMPLETED
  createdAt     DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Stock {
  id        String   @id @default(cuid())
  symbol    String   @unique
  name      String
  sector    String
  assetType String   // stock | etf | bond | commodity_etf | collectible | life_insurance | crypto | mutual_fund
  price     Float
  change    Float    @default(0)
  available Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model InsurancePlan {
  id        String   @id // "standard" | "premium"
  price     Float
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model Account {
  id            String   @id @default(cuid())
  userId        String
  type          String   // traditional | roth | sep | rollover
  brokerage     String   // brokerage id (see lib/data.js)
  label         String
  accountNumber String
  holder        String
  opened        String
  status        String   @default("ACTIVE") // ACTIVE | CLOSED
  origin        String   @default("LINKED") // LINKED | RECEIVED (created by a transfer)
  cashBalance   Float    @default(0)
  createdAt     DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions    Position[]
  outgoing     Transfer[]   @relation("SourceAccount")
  incoming     Transfer[]   @relation("DestAccount")
  withdrawals  Withdrawal[]
}

model Position {
  id        String  @id @default(cuid())
  accountId String
  symbol    String
  shares    Float

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Transfer {
  id              String   @id @default(cuid())
  reference       String   @unique
  userId          String
  sourceAccountId String
  destAccountId   String?  // receiving account, created/linked at settlement
  destBrokerage   String
  method          String   @default("EXTERNAL") // INTERNAL | EXTERNAL
  recipientHolder String
  recipientNumber String
  recipientType   String
  transferType    String   // FULL | PARTIAL
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED | SETTLED
  totalValue      Float
  items           String   // JSON: [{ symbol, shares, value }]
  // Optional transfer insurance the user can purchase to protect the transfer.
  insured          Boolean @default(false)
  insurancePlan    String? // none | standard | premium
  insurancePremium Float   @default(0)
  coverageAmount   Float   @default(0)
  note            String?  // admin note on reject/approve
  createdAt       DateTime @default(now())
  approvedAt      DateTime?
  settledAt       DateTime?
  rejectedAt      DateTime?
  updatedAt       DateTime @updatedAt

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source Account  @relation("SourceAccount", fields: [sourceAccountId], references: [id], onDelete: Cascade)
  dest   Account? @relation("DestAccount", fields: [destAccountId], references: [id], onDelete: SetNull)
}
