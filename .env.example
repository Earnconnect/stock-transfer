# ---------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit your real .env (it is git-ignored).
# ---------------------------------------------------------------------------

# Postgres (Neon). From the Neon dashboard -> Connection Details:
#   DATABASE_URL = POOLED connection (host contains "-pooler") for the app at runtime.
#   DIRECT_URL   = DIRECT connection (same host WITHOUT "-pooler") for db push.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Secret used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-with-a-long-random-string"

# Initial admin account created by `npm run db:seed`.
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="use-a-strong-password"
ADMIN_NAME="Platform Admin"

# Set to "true" to also seed the demo users/accounts (local development only).
SEED_DEMO="false"
